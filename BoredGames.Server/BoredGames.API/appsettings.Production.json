{
  "Keycloak": {
    "realm": "boredgames",
    "auth-server-url": "http://boredgames.keycloak.local:8080",
    "ssl-required": "internal",
    "resource": "boredgames-client",
    "audience": "account",
    "credentials": {
      "secret": "__KEYCLOAK_CLIENT_SECRET__"
    },
    "verify-token-audience": true,
    "confidential-port": 0
  },
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "Authority": "http://boredgames.keycloak.local/realms/boredgames",
        "RequireHttpsMetadata": false,
        "MetadataAddress": "http://boredgames.keycloak.local:8080/realms/boredgames/.well-known/openid-configuration",
        "TokenValidationParameters": {
          "ValidIssuer": "http://boredgames.keycloak.local/realms/boredgames",
          "ValidateIssuer": true
        }
      }
    }
  }
}
