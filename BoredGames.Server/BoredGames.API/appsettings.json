{
  "Keycloak": {
    "realm": "boredgames",
    "auth-server-url": "http://boredgames.keycloak.local:5555",
    "ssl-required": "internal",
    "resource": "boredgames-client",
    "credentials": {
      "secret": "0kw8Lse8HWXMvyLVUEU95kT3pReEaQAQ"
    },
    "verify-token-audience": false,
    "confidential-port": 0
  },
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "Authority": "http://boredgames.keycloak.local/realms/boredgames",
        "RequireHttpsMetadata": false,
        "MetadataAddress": "http://boredgames.keycloak.local:5555/realms/boredgames/.well-known/openid-configuration",
        "TokenValidationParameters": {
          "ValidIssuer": "http://boredgames.keycloak.local:5555/realms/boredgames",
          "ValidateIssuer": true
        }
      }
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "../logs/backend-log.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "ApplicationName": "BoredGames.API"
    }
  },
  "AllowedHosts": "*"
}
